# Application
APP_ENV=development
PORT=3000
LOG_LEVEL=info

# Swagger / OpenAPI docs
SWAGGER_ENABLED=true

# Client auth config (path to mounted JSON secret file)
CLIENTS_CONFIG_PATH=./secrets/clients.json

# Model provider: openai | amvera
MODEL_PROVIDER=openai
MODEL_NAME=qwen2.5-coder:7b
# MODEL_ENDPOINT=http://localhost:11434  # optional override (needed for Ollama/self-hosted)
# MODEL_API_KEY_PATH=./secrets/model-api-key.txt
# MODEL_TIMEOUT_MS=120000

# Request limits
REQUEST_BODY_LIMIT=1048576
REQUEST_TIMEOUT_MS=300000
