# =============================================================================
# Option 1 (recommended): Include the reusable template
# =============================================================================
# The review-ai repository provides a ready-to-use CI template.
# Just include it and set the required CI/CD variables.

workflow:
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

stages:
  - review

include:
  - project: 'infra/review-ai'       # adjust to your GitLab project path
    ref: main                          # pin to a tag for stability
    file: '/templates/review-ai.yml'

# The template provides a manual `ai-review` job out of the box.
# To customize variables:
#
#   ai-review:
#     variables:
#       REVIEW_PROFILE: "security"
#       REVIEW_USER_FOCUS: "Focus on auth and input validation"
#
# To enable automatic review on every MR push, set AI_REVIEW_AUTO in CI/CD variables:
#
#   ai-review:
#     variables:
#       AI_REVIEW_AUTO: "true"
#
# Required CI/CD variables (set as masked secrets in project settings):
#   AI_REVIEW_SERVICE_URL - URL of the review-ai service
#   AI_REVIEW_API_KEY     - Bearer token matching clients.json on the service
#   AI_REVIEW_CLIENT_ID   - Client ID matching clients.json on the service


